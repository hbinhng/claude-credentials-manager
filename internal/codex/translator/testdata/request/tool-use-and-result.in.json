{
  "model": "claude-opus-4.7",
  "tools": [
    {
      "name": "get_weather",
      "description": "Returns the current weather",
      "input_schema": {
        "type": "object",
        "properties": {
          "location": {"type": "string"}
        }
      }
    }
  ],
  "messages": [
    {
      "role": "user",
      "content": [{"type": "text", "text": "What's the weather in Paris?"}]
    },
    {
      "role": "assistant",
      "content": [
        {
          "type": "tool_use",
          "id": "tool-abc123",
          "name": "get_weather",
          "input": {"location": "Paris"}
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "tool_result",
          "tool_use_id": "tool-abc123",
          "content": "Sunny, 22°C"
        }
      ]
    }
  ]
}
